# Application
VITE_APP_NAME="2SI SARL - Commerce Hub"
VITE_APP_VERSION="2.0.0"
VITE_APP_ENV=development

# API Configuration
VITE_API_URL=https://2si.up.railway.app/api/v1
VITE_API_TIMEOUT=30000

# Modules Activation/Désactivation
# true = module activé (visible et accessible)
# false = module désactivé (masqué et inaccessible)

# Core Modules (toujours actifs - ne peuvent pas être désactivés)
VITE_MODULE_DASHBOARD_ENABLED=true

# Business Modules
VITE_MODULE_CRM_ENABLED=false
VITE_MODULE_ORDERS_ENABLED=false
VITE_MODULE_PRODUCTS_ENABLED=false
VITE_MODULE_REPORTS_ENABLED=false
VITE_MODULE_COMMERCIAL_ENABLED=true

# Feature Flags par Module Commercial
VITE_COMMERCIAL_CLIENTS_ENABLED=true
VITE_COMMERCIAL_COMMANDES_ENABLED=true
VITE_COMMERCIAL_CATALOGUE_ENABLED=true
VITE_COMMERCIAL_ACCREDITIF_ENABLED=false
VITE_COMMERCIAL_SIMULATION_ENABLED=true
VITE_COMMERCIAL_SAV_ENABLED=false
VITE_COMMERCIAL_RAPPORTS_ENABLED=false

# Payment & Licensing (futur)
# VITE_LICENSE_KEY=
# VITE_LICENSE_EXPIRY=

# Analytics (optionnel)
# VITE_ANALYTICS_ID=
# VITE_SENTRY_DSN=

# Upload Configuration
VITE_MAX_FILE_SIZE=10485760
VITE_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,application/pdf

# Maintenance Mode
VITE_MAINTENANCE_MODE=false
VITE_MAINTENANCE_MESSAGE="Le système est en maintenance. Veuillez réessayer plus tard."
